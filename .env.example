APP_NAME=TelegramOpenRouterBot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Telegram Config
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_secret_token_for_webhook
TELEGRAM_WEBHOOK_URL=https://your-app.onrender.com

# OpenRouter Config (Primary)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_DEFAULT=openai/gpt-3.5-turbo
OPENROUTER_MODEL_CODE=anthropic/claude-3-haiku
OPENROUTER_MODEL_RESEARCH=perplexity/sonar-small-chat
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_APP_NAME=TelegramOpenRouterBot

# Groq Config (Fallback)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_DEFAULT=mixtral-8x7b-32768
GROQ_MODEL_CODE=llama3-70b-8192

# LLM Routing Config
LLM_PRIMARY_PROVIDER=openrouter
LLM_FALLBACK_PROVIDER=groq
LLM_REQUEST_TIMEOUT=30
LLM_MAX_RETRIES=2

# Database Config
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb
LOG_LEVEL=INFO
