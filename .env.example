APP_NAME=TelegramOpenRouterBot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_secret_token_for_webhook
TELEGRAM_WEBHOOK_URL=https://your-app.onrender.com/webhook

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL_DEFAULT=openai/gpt-3.5-turbo
OPENROUTER_MODEL_CODE=anthropic/claude-3-haiku
OPENROUTER_MODEL_RESEARCH=perplexity/sonar-small-chat
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_APP_NAME=TelegramOpenRouterBot

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb
LOG_LEVEL=INFO
